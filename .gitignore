# ── OS artifacts ──────────────────────────────────────────────────────────────
*:Zone.Identifier
.DS_Store
Thumbs.db
desktop.ini

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Credentials & secrets — never commit these ────────────────────────────────
.env
.env.*
kaggle.json
*.pem
*.key

# ── App runtime state ─────────────────────────────────────────────────────────
.evalflow_manifest.json
.evalflow_slug_history.json
.evalflow_publish_state.json
outputs/
data/
jsons_from_tasks/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Markdown — only README.md is public ───────────────────────────────────────
*.md
!README.md

# ── Internal docs & tooling ───────────────────────────────────────────────────
docs/
.claude/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
